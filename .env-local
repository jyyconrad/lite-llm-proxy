
# API Gateway Configuration
DATABASE_URL=postgresql+asyncpg://postgres:admin1234@127.0.0.1:5433/litellm_gateway

REDIS_URL=redis://admin1234@127.0.0.1:6379
MASTER_KEY=admin1234
ADMIN_PASSWORD=admin1234
HTTP_PROXY=http://127.0.0.1:7897
HTTP_PROXYS=http://127.0.0.1:7897
# Server Configuration
HOST=0.0.0.0
PORT=9988
DEBUG=true
LOG_LEVEL=INFO

# Rate Limiting Configuration
DEFAULT_RPM_LIMIT=60
DEFAULT_TPM_LIMIT=60000
DEFAULT_BUDGET_LIMIT=1000.0

# Security Configuration
JWT_SECRET=your-jwt-secret-key-here
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# LLM Request Timeout Configuration (in seconds)
# Default: 300 seconds (5 minutes)
# Set to 0 to disable timeout
REQUEST_TIMEOUT=300

